# ============================================================
# AI 地址智能标准化工具 — 配置模板
# 复制本文件为 .env 并填入真实密钥，勿将 .env 提交到 Git
# ============================================================

LLM_PROVIDER=deepseek

CLAUDE_PROXY_BASE_URL=https://gaccode.com/claudecode
CLAUDE_PROXY_API_KEY=<your_claude_proxy_api_key>
CLAUDE_PROXY_MODEL=claude-3-5-sonnet-20241022

DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=<your_deepseek_api_key>
DEEPSEEK_MODEL=deepseek-chat

AMAP_API_KEY=<your_amap_web_service_key_optional>

HOST=0.0.0.0
PORT=8000
DEBUG=true
